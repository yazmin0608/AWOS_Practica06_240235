extends layout

block contenido
    div.max-w-6xl.mx-auto.mt-8
        div.bg-white.rounded-3xl.shadow-2xl.overflow-hidden.border.border-gray-100
            //- Encabezado con tu estilo Azul Deep
            div.bg-azul-deep.p-6.text-white.flex.items-center.justify-between
                div.flex.items-center.gap-3
                    span.text-3xl 📌
                    h2.text-2xl.font-bold Muro de Planeación Inmobiliaria
                span.bg-rojo-accent.px-4.py-1.rounded-full.text-xs.uppercase.font-black COLABORATIVO
            
            //- Contenedor del Padlet (Altura optimizada para pantallas grandes)
            div.p-4.bg-gray-100(style="height: 650px;")
                iframe(
                    src=`https://padlet.com/embed/${boardId}`
                    frameborder="0"
                    allow="camera; microphone; geolocation"
                    style="width: 100%; height: 100%; border-radius: 24px; border: 4px solid white;"
                )
            
            //- Pie de página del muro
            div.p-6.bg-white.text-center
                p.text-gray-500.font-medium 💡 Comparte ideas, planos o sugerencias de inversión con el equipo en tiempo real.