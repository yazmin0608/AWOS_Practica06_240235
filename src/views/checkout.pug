extends layout

block contenido
    div.max-w-2xl.mx-auto.mt-10
        div.bg-white.rounded-3xl.shadow-2xl.overflow-hidden.border.border-gray-100
            //- Encabezado Corporativo
            div.bg-azul-deep.p-6.text-white.flex.items-center.justify-between
                h2.text-2xl.font-bold 💳 Pasarela de Pagos
                span.bg-rojo-accent.px-3.py-1.rounded-full.text-xs.uppercase.font-bold Seguro
            
            div.p-8.text-center
                //- Información del Producto
                div.mb-6
                    h3.text-2xl.font-black.text-gray-800 Membresía Premium 2026
                    p.text-gray-500.mt-2 Accede a asesoría IA ilimitada y reportes de plusvalía en tiempo real.
                
                //- Cuadro de Precio con tu Matrícula/Puerto
                div.bg-gray-50.rounded-2xl.p-8.mb-8.border-2.border-dashed.border-gray-200
                    span.text-5xl.font-black.text-azul-deep $2,402.00
                    span.text-gray-400.text-lg.font-bold  MXN
                    p.text-xs.text-gray-400.mt-2 Pago único por acceso de por vida

                //- Botón de Acción con tu estilo 4xl
                button#checkout-btn(class="w-full bg-azul-deep text-white hover:bg-rojo-accent font-bold py-5 rounded-4xl shadow-xl uppercase transition-all duration-300 transform hover:scale-105 cursor-pointer flex items-center justify-center gap-3")
                    span#btn-text PAGAR CON MERCADO PAGO

    //- Script de Proceso Simulado (Rápido y Efectivo)
    script.
        const btn = document.getElementById('checkout-btn');
        const btnText = document.getElementById('btn-text');

        btn.addEventListener('click', async () => {
            // 1. Efecto Visual de "Cargando"
            btn.disabled = true;
            btn.classList.replace('bg-azul-deep', 'bg-gray-400');
            btnText.innerHTML = "🔄 Procesando Transacción...";

            try {
                // 2. Llamada al controlador (aunque sea simulado)
                const response = await fetch('/checkout/create_preference', { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                // 3. Pequeña pausa para que parezca que valida con el banco
                setTimeout(() => {
                    alert("✅ ¡Pago Autorizado! Tu membresía Premium ha sido activada.");
                    // Redirección directa al éxito (IA Dashboard)
                    window.location.href = "/ia";
                }, 1500);

            } catch (err) {
                console.error("Error en la pasarela:", err);
                btn.disabled = false;
                btnText.innerHTML = "REINTENTAR PAGO";
            }
        });